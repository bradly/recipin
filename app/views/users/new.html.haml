= content_for :subtitle do
  Sign up for an account

= form_for :user, url: users_path, class: 'flex flex-col gap-y-2 hover-link' do |form|
  .form-group
    = form.label :email
    = form.email_field :email

  .form-group
    = form.label :password
    = form.password_field :password

  .form-group
    = form.submit 'Sign up'

  %p.text-center.text-sm.muted
    Already have an account? #{link_to 'Sign in now', sign_in_path}
