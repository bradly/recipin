= content_for :title do
  Sign in to your account

%form.space-y-6{ action: "/users", method: "POST" }
  %div
    %label.block.text-sm.font-medium{ for: "email" } Email address
    .mt-2
      %input#email.block.w-full.rounded-md.border-0.text-gray-900.shadow-sm.ring-1.ring-inset.ring-gray-300.placeholder:text-gray-400.focus:ring-2.focus:ring-inset.focus:ring-indigo-600.sm:text-sm.sm:leading-6{ autocomplete: "email", class: "py-1.5", name: "email", required: "", type: "email" }/

  %div
    %label.block.text-sm.font-medium{ for: "password" } Password
    .mt-2
      %input#password.block.w-full.rounded-md.border-0.text-gray-900.shadow-sm.ring-1.ring-inset.ring-gray-300.placeholder:text-gray-400.focus:ring-2.focus:ring-inset.focus:ring-indigo-600.sm:text-sm.sm:leading-6{ autocomplete: "current-password", class: "py-1.5", name: "password", required: "", type: "password" }/

  %div
    %button.flex.w-full.justify-center.rounded-md.bg-indigo-600.px-3.text-sm.font-semibold.leading-6.text-white.shadow-sm.hover:bg-indigo-500.focus-visible:outline.focus-visible:outline-2.focus-visible:outline-offset-2.focus-visible:outline-indigo-600{ class: "py-1.5", type: "submit" } Sign in

%p.mt-10.text-center.text-sm.text-gray-500
  Don't have an account?
  = link_to 'Sign up now', sign_up_path, class: 'font-semibold leading-6 text-indigo-600 hover:text-indigo-500'
