= content_for :title do
  Sign in to your account

= form_for :session, url: session_path, class: 'flex flex-col gap-y-2' do |form|
  .form-group
    = form.label :email
    = form.text_field :email

  .form-group
    = form.label :password
    = form.password_field :password

  .form-group
    = form.submit 'Sign in'

  %p.text-center.text-sm.muted
    Don't have an account? #{link_to 'Sign up now', sign_up_path}
