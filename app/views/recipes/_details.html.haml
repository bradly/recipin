.flex.items-center.justify-between
  .flex.items-center.gap-x-6
    = image_tag @recipe.image_url, class: 'flex-none ring-1 ring-gray-900/10 w-16 h-16 rounded-full'
    %h1
      .mb-1.text-base.font-semibold= @recipe.name
      .text-xs.muted= @recipe.tags.join(', ')
  = link_to 'Add notes', recipe_path, class: 'ring-1 ring-gray-900/5 hover:ring-gray-200 rounded-md bg-gray-50 hover:bg-gray-100 px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600'
