%ul.divide-y.divide-gray-100
  %li.relative.flex.gap-x-6.py-5
    = image_tag 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80', class: 'h-12 w-12 flex-none rounded-full bg-gray-50'
    .flex.flex-col
      %p.text-sm.font-semibold.leading-6.text-gray-900
        = link_to recipe do
          = component_link
          = recipe.name

      %p.mt-1.flex.text-xs.leading-5.text-gray-500
        Last made <time datetime='#{recipe.created_at}'>#{time_ago_in_words recipe.created_at}</time>
