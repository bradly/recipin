%li.border.border-1.border-gray-200.rounded-lg.text-center.py-8.px-1.relative.hover:border-gray-300
  = link_to recipe do
    = component_link
    = image_tag recipe.image_url, class: 'mb-8 mx-auto h-32 w-32 rounded-full'
  %h3.text-sm.font-medium= recipe.name
  %p.text-sm.muted Last made <time datetime='#{recipe.created_at}'>#{time_ago_in_words recipe.created_at}</time>
